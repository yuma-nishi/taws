$(PROCESS_QUERY_REQUEST_TEST_BIN): $(PROCESS_QUERY_REQUEST_TEST_SRCS)
	@mkdir -p $(ROOT_DIR)/build
	$(CXX) -std=c++11 -g -IEnclave/inc -I$(ROOT_DIR)/common -I$(ROOT_DIR)/third_party/t_cose/inc -I$(ROOT_DIR)/third_party/QCBOR/inc -I$(ROOT_DIR)/third_party/libcsuit/inc -I$(ROOT_DIR)/third_party/libteep/inc $^ -L$(ROOT_DIR)/lib -lcsuit -lteep -lt_cose -lqcbor -lcrypto \
		-Wl,--wrap=suit_store_callback -Wl,--wrap=suit_condition_callback -Wl,--wrap=suit_report_callback \
		-o $@
	@echo "CXX  =>  $@"
