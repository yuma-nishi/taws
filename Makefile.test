#
# Test targets for attester
#

ROOT_DIR ?= $(CURDIR)

MANIFEST_RECORD_TEST_BIN := $(ROOT_DIR)/build/manifest_record_store_test
SUIT_CONDITION_CALLBACK_TEST_BIN := $(ROOT_DIR)/build/suit_condition_callback_test
ENCLAVE_WASM_INVOKE_TEST_BIN := $(ROOT_DIR)/build/enclave_wasm_invoke_test
TC_UPDATE_INTEGRATION_TEST_BIN := $(ROOT_DIR)/build/tc_update_integration_test
TC_MANAGER_GET_TC_LIST_TEST_BIN := $(ROOT_DIR)/build/tc_manager_get_tc_list_test
PROCESS_QUERY_REQUEST_TEST_BIN := $(ROOT_DIR)/build/proces_query_request_test

.PHONY: all manifest-record-store-test suit-condition-callback-test enclave-wasm-invoke-test tc-update-integration-test tc-manager-get-tc-list-test process-query-request-test clean run


all: $(MANIFEST_RECORD_TEST_BIN) $(SUIT_CONDITION_CALLBACK_TEST_BIN) $(ENCLAVE_WASM_INVOKE_TEST_BIN) $(TC_UPDATE_INTEGRATION_TEST_BIN) $(TC_MANAGER_GET_TC_LIST_TEST_BIN) $(PROCESS_QUERY_REQUEST_TEST_BIN)

clean:
	$(RM) $(MANIFEST_RECORD_TEST_BIN) $(SUIT_CONDITION_CALLBACK_TEST_BIN) $(ENCLAVE_WASM_INVOKE_TEST_BIN) $(TC_UPDATE_INTEGRATION_TEST_BIN) $(TC_MANAGER_GET_TC_LIST_TEST_BIN) $(PROCESS_QUERY_REQUEST_TEST_BIN)

run: manifest-record-store-test suit-condition-callback-test enclave-wasm-invoke-test tc-update-integration-test tc-manager-get-tc-list-test process-query-request-test



MANIFEST_RECORD_TEST_SRCS := Enclave/tests/manifest_record_store_test.cpp Enclave/src/tc_manager.cpp

manifest-record-store-test: $(MANIFEST_RECORD_TEST_BIN)
	$(MANIFEST_RECORD_TEST_BIN)

$(MANIFEST_RECORD_TEST_BIN): $(MANIFEST_RECORD_TEST_SRCS)
	@mkdir -p $(ROOT_DIR)/build
	$(CXX) -std=c++11 -g -IEnclave/inc -I$(ROOT_DIR)/common -I$(ROOT_DIR)/third_party/t_cose/inc -I$(ROOT_DIR)/third_party/QCBOR/inc -I$(ROOT_DIR)/third_party/libcsuit/inc -I$(ROOT_DIR)/third_party/libteep/inc $^ -L$(ROOT_DIR)/lib -lcsuit -lteep -lt_cose -lqcbor -lcrypto -o $@
	@echo "CXX  =>  $@"


SUIT_CONDITION_CALLBACK_TEST_SRCS := Enclave/tests/suit_condition_callback_test.cpp \
	Enclave/tests/test_helpers.cpp \
	Enclave/src/suit_processor_wrapper.cpp \
	Enclave/src/tc_manager.cpp

suit-condition-callback-test: $(SUIT_CONDITION_CALLBACK_TEST_BIN)
	$(SUIT_CONDITION_CALLBACK_TEST_BIN)

$(SUIT_CONDITION_CALLBACK_TEST_BIN): $(SUIT_CONDITION_CALLBACK_TEST_SRCS)
	@mkdir -p $(ROOT_DIR)/build
	$(CXX) -std=c++11 -g -IEnclave/inc -I$(ROOT_DIR)/common -I$(ROOT_DIR)/third_party/t_cose/inc -I$(ROOT_DIR)/third_party/QCBOR/inc -I$(ROOT_DIR)/third_party/libcsuit/inc -I$(ROOT_DIR)/third_party/libteep/inc $^ -L$(ROOT_DIR)/lib -lcsuit -lteep -lt_cose -lqcbor -lcrypto \
		-Wl,--wrap=suit_store_callback -Wl,--wrap=suit_condition_callback -Wl,--wrap=suit_report_callback \
		-o $@
	@echo "CXX  =>  $@"


ENCLAVE_WASM_INVOKE_TEST_SRCS := Enclave/tests/enclave_wasm_invoke_test.cpp \
	Enclave/src/Enclave_wasm.cpp

enclave-wasm-invoke-test: $(ENCLAVE_WASM_INVOKE_TEST_BIN)
	$(ENCLAVE_WASM_INVOKE_TEST_BIN)

$(ENCLAVE_WASM_INVOKE_TEST_BIN): $(ENCLAVE_WASM_INVOKE_TEST_SRCS)
	@mkdir -p $(ROOT_DIR)/build
	$(CXX) -std=c++11 -g \
		-IEnclave/inc \
		-I$(ROOT_DIR)/common \
		-I$(ROOT_DIR)/third_party/t_cose/inc \
		-I$(ROOT_DIR)/third_party/QCBOR/inc \
		-I$(ROOT_DIR)/third_party/libcsuit/inc \
		-I$(ROOT_DIR)/third_party/libteep/inc \
		-I$(ROOT_DIR)/third_party/wasm-micro-runtime/core/iwasm/include \
		-I$(ROOT_DIR)/third_party/wasm-micro-runtime/core/shared/utils \
		-I$(ROOT_DIR)/third_party/wasm-micro-runtime/core/shared/platform/include \
		-I$(ROOT_DIR)/third_party/wasm-micro-runtime/core/shared/platform/linux-sgx \
		-I$(SGX_SDK)/include \
		$^ -L$(ROOT_DIR)/lib -lcsuit -lt_cose -lqcbor -lcrypto -o $@
	@echo "CXX  =>  $@"


TC_UPDATE_INTEGRATION_TEST_SRCS := Enclave/tests/tc_update_integration_test.cpp \
	Enclave/src/suit_processor_wrapper.cpp \
	Enclave/src/tc_manager.cpp

tc-update-integration-test: $(TC_UPDATE_INTEGRATION_TEST_BIN)
	$(TC_UPDATE_INTEGRATION_TEST_BIN)

$(TC_UPDATE_INTEGRATION_TEST_BIN): $(TC_UPDATE_INTEGRATION_TEST_SRCS)
	@mkdir -p $(ROOT_DIR)/build
	$(CXX) -std=c++11 -g -IEnclave/inc -I$(ROOT_DIR)/common -I$(ROOT_DIR)/third_party/t_cose/inc -I$(ROOT_DIR)/third_party/QCBOR/inc -I$(ROOT_DIR)/third_party/libcsuit/inc -I$(ROOT_DIR)/third_party/libteep/inc $^ -L$(ROOT_DIR)/lib -lcsuit -lteep -lt_cose -lqcbor -lcrypto \
		-Wl,--wrap=suit_store_callback -Wl,--wrap=suit_condition_callback -Wl,--wrap=suit_report_callback \
		-o $@
	@echo "CXX  =>  $@"


