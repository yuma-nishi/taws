	@echo "CXX  =>  $@"


PROCESS_QUERY_REQUEST_TEST_SRCS := Enclave/tests/proces_query_request_test.cpp \
	Enclave/tests/test_helpers.cpp \
	Enclave/src/Enclave_process_message.cpp \
	Enclave/src/suit_processor_wrapper.cpp \
	Enclave/src/tc_manager.cpp

process-query-request-test: $(PROCESS_QUERY_REQUEST_TEST_BIN)
